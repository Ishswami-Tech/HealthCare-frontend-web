# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# This file is for production deployment
# Matches backend production configuration from HealthCareBackend/.env.production
# Backend is live at: https://backend-service-v1.ishswami.in
# ============================================================================

# Environment
NODE_ENV=production

# ============================================================================
# API Configuration - Production Server
# ============================================================================
# Backend API: https://backend-service-v1.ishswami.in
NEXT_PUBLIC_API_URL=https://backend-service-v1.ishswami.in
NEXT_PUBLIC_API_BASE_URL=https://backend-service-v1.ishswami.in
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_CLINIC_API_URL=https://backend-service-v1.ishswami.in

# ============================================================================
# WebSocket Configuration - Production
# ============================================================================
NEXT_PUBLIC_WEBSOCKET_URL=wss://backend-service-v1.ishswami.in/socket.io
NEXT_PUBLIC_WS_URL=wss://backend-service-v1.ishswami.in/socket.io
NEXT_PUBLIC_WS_TIMEOUT=20000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=15

# ============================================================================
# Application URLs - Production
# ============================================================================
# Frontend URL (matches backend FRONTEND_URL)
NEXT_PUBLIC_APP_URL=https://ishswami.in
# Main domain (matches backend MAIN_DOMAIN)
NEXT_PUBLIC_MAIN_DOMAIN=viddhakarma.com
# Frontend domain (matches backend FRONTEND_DOMAIN)
NEXT_PUBLIC_FRONTEND_DOMAIN=viddhakarma.com

# ============================================================================
# Authentication Configuration
# ============================================================================
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=616510725595-icnj6ql0qie97dp4voi3u9uafbnmhend.apps.googleusercontent.com
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# ============================================================================
# Clinic Configuration
# ============================================================================
NEXT_PUBLIC_CLINIC_ID=CL0002
NEXT_PUBLIC_APP_NAME=Healthcare

# ============================================================================
# Video Configuration - Production
# ============================================================================
# OpenVidu Server URL (matches backend OPENVIDU_URL)
NEXT_PUBLIC_OPENVIDU_SERVER_URL=https://backend-service-v1-video.ishswami.in
# Jitsi Configuration (Fallback Video Provider - matches backend)
NEXT_PUBLIC_JITSI_DOMAIN=meet.ishswami.in
NEXT_PUBLIC_JITSI_BASE_URL=https://meet.ishswami.in
NEXT_PUBLIC_JITSI_WS_URL=wss://meet.ishswami.in/xmpp-websocket

# ============================================================================
# Feature Flags - Production
# ============================================================================
NEXT_PUBLIC_ENABLE_REAL_TIME=true
NEXT_PUBLIC_ENABLE_VIDEO_CALLS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_HTTPS=true
NEXT_PUBLIC_ENABLE_CORS=true

# ============================================================================
# Debug & Monitoring - Production
# ============================================================================
NEXT_PUBLIC_DEBUG_BACKEND_STATUS=false
NEXT_PUBLIC_HEALTH_CHECK_INTERVAL=60000
NEXT_PUBLIC_BACKEND_URL=https://backend-service-v1.ishswami.in

# ============================================================================
# Application Configuration
# ============================================================================
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================================================
# Logging - Production
# ============================================================================
NEXT_PUBLIC_LOG_LEVEL=error
NEXT_PUBLIC_ENABLE_CONSOLE_LOGS=false

# ============================================================================
# Payment Configuration - Cashfree (Production)
# ============================================================================
# Use production Cashfree credentials in production
# Update these values with your production Cashfree keys
NEXT_PUBLIC_ENABLED_PAYMENT_PROVIDERS=cashfree
NEXT_PUBLIC_CASHFREE_MODE=production
NEXT_PUBLIC_CASHFREE_APP_ID=your-production-cashfree-app-id
NEXT_PUBLIC_CASHFREE_API_VERSION=2025-01-01
NEXT_PUBLIC_APP_URL=https://ishswami.in 