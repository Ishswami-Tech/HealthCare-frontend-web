# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.local, .env.development, .env.staging, or .env.production
# and update the values according to your environment

# Environment
NODE_ENV=development

# API Configuration
# Canonical API URL variables:
# - NEXT_PUBLIC_API_BASE_URL: backend origin (canonical)
# - NEXT_PUBLIC_WEBSOCKET_URL: websocket endpoint
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_CLINIC_API_URL=http://localhost:8088
NEXT_PUBLIC_API_PREFIX=/api/v1

# WebSocket Configuration
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:8088
NEXT_PUBLIC_WS_URL=http://localhost:8088
NEXT_PUBLIC_BACKEND_URL=http://localhost:8088

# Server-only protection token used by Vercel server actions when Cloudflare protects the backend
BACKEND_PROTECTION_KEY=

# Authentication Configuration
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id

# Clinic Configuration
NEXT_PUBLIC_CLINIC_ID=CL0002
NEXT_PUBLIC_APP_NAME=Healthcare

# Feature Flags
NEXT_PUBLIC_ENABLE_REAL_TIME=true
NEXT_PUBLIC_ENABLE_VIDEO_CALLS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_HTTPS=false
NEXT_PUBLIC_ENABLE_CORS=true

# Debug & Monitoring
NEXT_PUBLIC_DEBUG_BACKEND_STATUS=true
NEXT_PUBLIC_HEALTH_CHECK_INTERVAL=15000
NEXT_PUBLIC_WS_TIMEOUT=10000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=5
NEXT_PUBLIC_DEBUG_BACKEND_STATUS=true

# Video Configuration
NEXT_PUBLIC_VIDEO_NO_SHOW_ENABLED=false
NEXT_PUBLIC_MAIN_DOMAIN=localhost
NEXT_PUBLIC_FRONTEND_DOMAIN=localhost

# Application Configuration
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================================================
# Payment Configuration
# ============================================================================
# Bridge-first setup:
# - Set NEXT_PUBLIC_PAYMENT_BRIDGE_URL for production payment initiation.
# - Direct provider envs below are legacy/optional and only needed if bridge is disabled.
# Comma-separated list of enabled providers: cashfree,razorpay,phonepe,easebuzz,paytm,payu
NEXT_PUBLIC_ENABLED_PAYMENT_PROVIDERS=cashfree,razorpay,phonepe,easebuzz,paytm,payu
# Optional bridge URL for handing payment initiation to Ishswami-owned payment origin
NEXT_PUBLIC_PAYMENT_BRIDGE_URL=https://ishswami.in/payments/start

# Cashfree
NEXT_PUBLIC_CASHFREE_MODE=sandbox
NEXT_PUBLIC_CASHFREE_APP_ID=
NEXT_PUBLIC_CASHFREE_API_VERSION=2025-01-01

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Easebuzz
NEXT_PUBLIC_EASEBUZZ_MODE=test
NEXT_PUBLIC_EASEBUZZ_MERCHANT_KEY=
NEXT_PUBLIC_EASEBUZZ_MERCHANT_ID=
NEXT_PUBLIC_EASEBUZZ_API_BASE_URL=https://test.easebuzz.in/

# Paytm Business
NEXT_PUBLIC_PAYTM_MODE=STAGING
NEXT_PUBLIC_PAYTM_MERCHANT_ID=
NEXT_PUBLIC_PAYTM_MERCHANT_KEY=
NEXT_PUBLIC_PAYTM_WEBSITE=
NEXT_PUBLIC_PAYTM_INDUSTRY_TYPE_ID=

# PayU
NEXT_PUBLIC_PAYU_MODE=test
NEXT_PUBLIC_PAYU_MERCHANT_KEY=
NEXT_PUBLIC_PAYU_MERCHANT_SALT=
NEXT_PUBLIC_PAYU_CLIENT_ID=
NEXT_PUBLIC_PAYU_CLIENT_SECRET=

# ============================================================================
# YouTube Configuration
# ============================================================================
# YouTube Data API key for fetching videos from Dr. Chandrakumar Deshmukh's channel
# Get your API key from: https://console.cloud.google.com/
# Channel ID: UCvYvYvYvYvYvYvYvYvYvYvY (Replace with actual channel ID)
NEXT_PUBLIC_YOUTUBE_API_KEY=your-youtube-api-key-here

# ============================================================================
# Application URL
# ============================================================================
# Used for payment callbacks and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_ENABLE_CONSOLE_LOGS=true 
